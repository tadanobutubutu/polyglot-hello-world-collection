  set i, 0xf615\n  set j, 0x7349\n  hwn z\n  sub z, 1\n\n:device_detect_loop\n  hwq z\n\n  ife a, i\n    ife b, j\n      set pc, device_detect_ret\n\n  sub z, 1\n  ifa z, 0xffff\n    set pc, device_detect_loop\n\n:device_detect_ret\n  set a, 0\n  set b, [vidmem]\n  hwi z\n\n  set i, [vidmem]\n  set j, string\n  set c, 0xc\n\n:memcpy_loop\n  bor [j], 0xf000 ; OR with font style.\n  sti [i], [j]\n  sub c, 1\n  ife c, 0\n    sub pc, 1\n  set pc, memcpy_loop\n\n:display dat 0\n:vidmem dat 0x8000\n:string dat \"Hello World!\"